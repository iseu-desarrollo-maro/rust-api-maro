{
    "name": "Rust DevContainer",
    "image": "mcr.microsoft.com/vscode/devcontainers/rust:latest",
    "runArgs": [
        "--env-file",
        ".env"
    ],
    "customizations": {
        "vscode": {
            "settings": {
                "terminal.integrated.shell.linux": "/bin/bash"
            },
            "extensions": [
                "rust-lang.rust-analyzer"
            ]
        }
    }
}